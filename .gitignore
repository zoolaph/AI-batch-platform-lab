venv/
.pytest_cache/

# Ansible
*.retry

# Kubernetes
kubeconfig
kubeconfig.*
*.kubeconfig

# Secrets and environment
.env
.env.*
secrets/
credentials.json

# Node (cost reporter / tooling)
node_modules/

# Editor and OS
.DS_Store
.idea/
.vscode/
*.swp
*.swo
*~
Thumbs.db
